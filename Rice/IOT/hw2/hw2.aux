\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Throughput comparison (items/sec, log scale). The exact algorithm achieves $\sim $230M items/sec regardless of $W$. The approximate algorithm achieves $\sim $37--49M items/sec (compiled with \texttt  {-O0}, no optimizations). Throughput is relatively insensitive to $k$ and $W$.}}{12}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Memory footprint comparison (bytes, log scale). The exact algorithm uses $W$ bytes ($\Theta (W)$). The approximate algorithm uses $O(k \log W)$ bytes --- for example, at $W = 1{,}000{,}000$ with $k = 10$, it uses only 1{,}056 bytes vs.\ 1{,}000{,}000 bytes for exact, a $\sim $950$\times $ reduction.}}{12}{}\protected@file@percent }
